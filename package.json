{
  "name": "getember",
  "version": "0.3.4",
  "description": "Personal todo MCP server for Claude Code",
  "type": "module",
  "bin": {
    "getember": "dist/index.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hyunjae-labs/ember.git"
  },
  "main": "./dist/index.js",
  "files": [
    "dist/",
    ".claude-plugin/",
    "skills/",
    "package.json"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=20 <24"
  },
  "keywords": [
    "mcp",
    "claude",
    "todo",
    "task",
    "ember"
  ],
  "license": "MIT",
  "dependencies": {
    "@huggingface/transformers": "^3.8.1",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "better-sqlite3": "^12.8.0",
    "sqlite-vec": "^0.1.7"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.5.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
